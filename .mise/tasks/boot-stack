#!/usr/bin/env bash
set -e
#MISE description="Generate Postgres init SQL and boot Redis + Postgres"
#MISE alias="bs"
#USAGE flag "--ui" help="Also start UI companions (pgAdmin, RedisInsight)"
#USAGE flag "--monitoring" help="Also start monitoring stack (Prometheus, Grafana, Loki)"

COMPOSE_FILES=(-f "$COMPOSE_DB" -f "$COMPOSE_REDIS")
[ "${usage_monitoring:-false}" = "true" ] && COMPOSE_FILES+=(-f "$COMPOSE_MONITORING")

PROFILES=(--profile infra)
[ "${usage_ui:-false}" = "true" ] && PROFILES+=(--profile infra-ui)
[ "${usage_monitoring:-false}" = "true" ] && PROFILES+=(--profile monitoring)

mise run db:generate-init
docker compose "${COMPOSE_FILES[@]}" "${PROFILES[@]}" up -d --remove-orphans
