#!/usr/bin/env bash
#MISE description="Build and start full stack with monitoring stack"
#MISE alias="fsm"
mise run init-env
./scripts/generate-postgres-init.sh
docker compose -f "$COMPOSE_DB" -f "$COMPOSE_REDIS" -f "$COMPOSE_MONITORING" -f "$COMPOSE_FULL" --profile services up -d --build --remove-orphans postgres redis auth-service
./scripts/pre-register-services.sh
docker compose -f "$COMPOSE_DB" -f "$COMPOSE_REDIS" -f "$COMPOSE_MONITORING" -f "$COMPOSE_FULL" --profile services --profile monitoring up -d --build --remove-orphans
