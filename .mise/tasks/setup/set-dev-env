#!/usr/bin/env bash
set -euo pipefail
#MISE description="Set APP_ENV=development and DEBUG=true in all registry service .env files"
#MISE alias="sde"

upsert_env_key() {
  local env_file="$1"
  local key="$2"
  local value="$3"

  if grep -qE "^${key}=" "${env_file}"; then
    sed -i -E "s|^${key}=.*$|${key}=${value}|" "${env_file}"
  else
    printf "%s=%s\n" "${key}" "${value}" >> "${env_file}"
  fi
}

python3 .mise/scripts/service_registry.py validate >/dev/null

while IFS=$'\t' read -r service_id _repo_path env_file_rel; do
  env_file="${env_file_rel}"
  if [[ "${env_file}" != /* ]]; then
    env_file="${PWD}/${env_file#./}"
  fi

  if [[ ! -f "${env_file}" ]]; then
    echo "Skipping ${service_id}: ${env_file} not found." >&2
    continue
  fi

  upsert_env_key "${env_file}" "APP_ENV" "development"
  upsert_env_key "${env_file}" "DEBUG" "true"
  echo "Set APP_ENV=development and DEBUG=true in ${env_file}"
done < <(python3 .mise/scripts/service_registry.py service-envs)
