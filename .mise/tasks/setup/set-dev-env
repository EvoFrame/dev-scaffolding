#!/usr/bin/env bash
set -euo pipefail
#MISE description="Set APP_ENV=development and DEBUG=true in all cloned repo .env files"
#MISE alias="sde"

ENV_FILE=".env"
if [[ ! -f "${ENV_FILE}" ]]; then
  ENV_FILE=".env.example"
fi

if [[ ! -f "${ENV_FILE}" ]]; then
  echo "No .env or .env.example file found." >&2
  exit 1
fi

upsert_env_key() {
  local env_file="$1"
  local key="$2"
  local value="$3"

  if grep -qE "^${key}=" "${env_file}"; then
    sed -i -E "s|^${key}=.*$|${key}=${value}|" "${env_file}"
  else
    printf "%s=%s\n" "${key}" "${value}" >> "${env_file}"
  fi
}

mapfile -t repo_prefixes < <(
  grep -E '^[A-Z0-9_]+_REPO_PATH=' "${ENV_FILE}" | sed -E 's/=.*$//' | sed -E 's/_REPO_PATH$//' || true
)

for prefix in "${repo_prefixes[@]}"; do
  repo_path="$(grep -E "^${prefix}_REPO_PATH=" "${ENV_FILE}" | head -n1 | cut -d= -f2- || true)"
  repo_path="${repo_path%\"}"
  repo_path="${repo_path#\"}"
  repo_path="${repo_path%\'}"
  repo_path="${repo_path#\'}"

  if [[ -z "${repo_path}" ]]; then
    continue
  fi

  target_path="${repo_path}"
  if [[ "${target_path}" != /* ]]; then
    target_path="${PWD}/${target_path#./}"
  fi

  env_file="${target_path}/.env"
  if [[ ! -f "${env_file}" ]]; then
    echo "Skipping ${prefix}: ${env_file} not found." >&2
    continue
  fi

  upsert_env_key "${env_file}" "APP_ENV" "development"
  upsert_env_key "${env_file}" "DEBUG" "true"
  echo "Set APP_ENV=development and DEBUG=true in ${env_file}"
done
