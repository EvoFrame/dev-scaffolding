#!/usr/bin/env bash
set -euo pipefail
#MISE description="Remove cloned repositories defined in config/services.toml"
#MISE alias="rcl"

python3 .mise/scripts/service_registry.py validate >/dev/null

while IFS=$'\t' read -r service_id _url _branch repo_path; do
  target_path="${repo_path}"
  if [[ "${target_path}" != /* ]]; then
    target_path="${PWD}/${target_path#./}"
  fi
  if [[ "${target_path}" == "/" || "${target_path}" == "${PWD}" ]]; then
    echo "Skipping ${service_id}: refusing to remove unsafe path ${target_path}." >&2
    continue
  fi

  if [[ -d "${target_path}" ]]; then
    rm -rf "${target_path}"
    echo "Removed ${service_id} -> ${target_path}"
  else
    echo "Skipped ${service_id}: ${target_path} does not exist."
  fi
done < <(python3 .mise/scripts/service_registry.py repos)
