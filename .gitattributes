# .gitattributes
#
# Controls how Git handles line endings and diffs across all platforms.
#
# Key attributes used in this file:
#   text          Normalize line endings on commit (CRLF → LF in the repo).
#   eol=lf        Always check out with LF (Linux/macOS/Docker scripts).
#   eol=crlf      Always check out with CRLF (Windows-only scripts: .bat, .ps1).
#   -diff         Skip diff output for this file type (reduces noise for generated/binary-ish files).
#   binary        Shorthand for "-text -diff" — no normalization, no diffing.

# Fallback: Git auto-detects text vs. binary for any file not listed below.
# Text files default to LF line endings in the repo and on checkout.
* text=auto eol=lf

# Source code
# .bat/.cmd/.ps1 use CRLF because Windows requires it for these script types.
# All other source files use LF.
# .map files skip diffing — they are generated source maps and diffs are unreadable.
*.bash text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.coffee text
*.css text diff=css
*.htm text diff=html
*.html text diff=html
*.inc text
*.ini text
*.js text
*.mjs text
*.cjs text
*.json text
*.jsx text
*.less text
*.ls text
*.map text -diff
*.od text
*.onlydata text
*.php text diff=php
*.pl text
*.ps1 text eol=crlf
*.py text diff=python
*.rb text diff=ruby
*.sass text
*.scm text
*.scss text diff=css
*.sh text eol=lf
.husky/* text eol=lf
*.sql text
*.styl text
*.tag text
*.ts text
*.tsx text
*.xml text
*.xhtml text diff=html

# Docker
# Ensure Dockerfiles always use LF regardless of the developer's OS.
Dockerfile text

# Documentation
# Notebooks use LF so multi-platform teams don't produce spurious line-ending diffs.
*.ipynb text eol=lf
*.markdown text diff=markdown
*.md text diff=markdown
*.mdwn text diff=markdown
*.mdown text diff=markdown
*.mkd text diff=markdown
*.mkdn text diff=markdown
*.mdtxt text
*.mdtext text
*.txt text
AUTHORS text
CHANGELOG text
CHANGES text
CONTRIBUTING text
COPYING text
copyright text
*COPYRIGHT* text
INSTALL text
license text
LICENSE text
NEWS text
readme text
*README* text
TODO text

