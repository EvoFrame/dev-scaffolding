# Fonts
*.ttf binary
*.eot binary
*.otf binary
*.woff binary
*.woff2 binary

# Executables
# .pyc files are Python bytecode — always binary, never committed intentionally.
# Yarn release/plugin bundles are vendored minified JS; marking them binary
# prevents massive diffs when Yarn updates itself.
*.exe binary
*.pyc binary
**/.yarn/releases/** binary
**/.yarn/plugins/** binary

# RC files — tooling configs like .babelrc, .eslintrc
*.*rc text

# Ignore files — like .npmignore or .gitignore
*.*ignore text

# Build output: mark as binary so dist changes don't produce diff noise
dist/* binary
