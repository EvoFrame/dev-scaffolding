# Configs
# Lock files are marked -diff because their auto-generated content creates
# thousands of noisy diff lines that obscure real changes in code review.
# package.json and package-lock.json enforce LF so they're consistent in Docker builds.
*.cnf text
*.conf text
*.config text
.editorconfig text
.env text
.gitattributes text
.gitconfig text
.htaccess text
*.lock text -diff
package.json text eol=lf
package-lock.json text eol=lf -diff
pnpm-lock.yaml text eol=lf -diff
.prettierrc text
yarn.lock text -diff
*.toml text
*.yaml text
*.yml text
browserslist text
Makefile text
makefile text
# tsconfig.json is rendered as "JSON with Comments" on GitHub so // comments highlight correctly.
tsconfig.json linguist-language=JSON-with-Comments

# Heroku
# Procfile must be LF-terminated for the Heroku platform to parse it correctly.
Procfile text

# Graphics
# All raster and vector image formats are treated as binary — no line-ending
# normalization or diff output.
# SVG is kept as text (not binary) so it can be diffed and reviewed in PRs.
# To treat SVGs as opaque assets instead, replace the line below with: *.svg binary
*.ai binary
*.bmp binary
*.eps binary
*.gif binary
*.gifv binary
*.ico binary
*.jng binary
*.jp2 binary
*.jpg binary
*.jpeg binary
*.jpx binary
*.jxr binary
*.pdf binary
*.png binary
*.psb binary
*.psd binary
*.svg text
*.svgz binary
*.tif binary
*.tiff binary
*.wbmp binary
*.webp binary

